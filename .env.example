# Cursor Cloud API (Basic auth). Dashboard → Integrations / Cloud Agents.
CURSOR_API_KEY=cursor_...

# After each agent finishes: archive (default) | delete | none
# Builder is stopped before waiting for Greptile; each fix uses a new agent, then stopped.
# CURSOR_STOP_AGENT=archive

# Optional explicit model (see GET https://api.cursor.com/v1/models)
# CURSOR_MODEL=composer-2

# Builder startingRef: default tries plain branch name then refs/heads/<branch> (Cursor’s GitHub App may 404 full refs).
# Set to 1 to try refs/heads first instead.
# CURSOR_STARTING_REF_REFS_FIRST=1
# Last resort (often rejected — Cursor treats SHA like a branch name):
# CURSOR_TRY_COMMIT_SHA_FOR_STARTING_REF=1

# If Cursor omits branchName on the agent, pick newest open PR whose head ref starts with this prefix:
# CURSOR_PR_HEAD_PREFIX=cursor/

# GitHub PAT: repo contents/metadata/pulls; for Greptile **check runs** add Checks **Read**
# (fine-grained PAT → Permissions → Repository permissions → Checks: Read-only).
GITHUB_TOKEN=ghp_...
GITHUB_REPO=your-org/your-repo
# Optional: override starting branch for the builder agent. If unset, uses GitHub API default_branch.
# GITHUB_DEFAULT_BRANCH=main

# Optional: default builder task (use orchestrate --prompt or -i to override from the CLI)
# BUILDER_PROMPT=Add a README section on agent ergonomics.

# Greptile heuristics (comma-separated substrings, case-insensitive)
GREPTILE_BOT_SUBSTRINGS=greptile
GREPTILE_CHECK_SUBSTRINGS=greptile
# Optional substrings meaning “nothing left to fix” (also detects safe-to-merge / 5-of-5 heuristics).
# GREPTILE_CLEAN_SUBSTRINGS=

# Polling (seconds)
GREPTILE_POLL_INTERVAL_S=20
GREPTILE_POLL_BUDGET_S=900

# Fix loop (each round = new cloud agent on the PR after Greptile signal)
MAX_FIX_ROUNDS=3
# Demos only: parallel fix agents (same-branch conflicts possible; keep 1 for safety)
MAX_PARALLEL_FIXERS=1
MAX_FEEDBACK_CHUNKS=6
FIX_ROUND_COOLDOWN_S=45

# Optional: CLōD (https://clod.io/) — OpenAI-compatible API (dashboard → API Keys).
# CLOD_API_KEY=
# CLOD_BASE_URL=https://api.clod.io/v1
# CLOD_MODEL=Claude Opus 4.6
# CLOD_TIMEOUT_S=60
# CLOD_MAX_INPUT_CHARS=24000
# CLOD_MAX_COMPLETION_TOKENS=2048
#
# Greptile → CLōD summarization before each Cursor *fix* agent (unset CLOD_API_KEY disables all CLōD).
# CLOD_COMPRESS_FOR_FIX=1   # set 0 to disable compression but keep validator below
#
# Second reviewer: CLōD reads Greptile summary + PR unified diffs; prints VERDICT: PASS|FAIL.
# CLOD_VALIDATOR=1
# CLOD_VALIDATOR_APPEND_PR_BODY=1   # replace/add marked CLōD validator blurb in PR description
# CLOD_VALIDATOR_COMMENT_PR=1       # post timeline comment on PR (fine-grained PAT: Issues Read/Write or Pull requests as needed)
# CLOD_VALIDATOR_STRICT=1   # FAIL → exit before REST merge / merge wait (UNKNOWN never blocks)
# CLOD_VALIDATOR_MAX_PATCH_CHARS=28000
# CLOD_VALIDATOR_MAX_GREPTILE_CHARS=12000
# CLOD_VALIDATOR_TIMEOUT_S=120
# CLOD_VALIDATOR_MAX_COMPLETION_TOKENS=1536
# CLOD_VALIDATOR_PR_MAX_CHARS=45000   # cap for PR description CLōD section (comment uses ~65k GitHub max)

# Queue GitHub auto-merge when the PR is opened (merge | squash | rebase).
# Fine-grained PAT: Pull requests Read and write + repo access (+ SSO authorize if org).
# Repo → Settings → General → Pull Requests → Allow auto-merge (required).
# When queueing succeeds, GITHUB_MERGE_ON_GREPTILE_CLEAN is skipped for that PR.
# GITHUB_AUTO_MERGE=squash

# Or merge via REST after Greptile + fixes (no “Allow auto-merge”). Polls until mergeable_state=clean.
# If both GITHUB_AUTO_MERGE and GITHUB_MERGE_IMMEDIATE are set, only immediate REST merge runs.
# GITHUB_MERGE_IMMEDIATE=squash

# REST-merge only when Greptile feedback looks clean (skipped fix loop). Handy with CONTINUOUS_BUILDS when GraphQL auto-merge fails.
# GITHUB_MERGE_ON_GREPTILE_CLEAN=squash
# GITHUB_MERGE_POLL_BUDGET_S=7200
# GITHUB_MERGE_POLL_INTERVAL_S=15

# After each full cycle, wait for PR merge then start another builder (or use CLI --continuous).
# CONTINUOUS_BUILDS=1
# CONTINUOUS_MERGE_WAIT_S=7200
# CONTINUOUS_POLL_INTERVAL_S=15
# CONTINUOUS_SLEEP_BETWEEN_S=5
